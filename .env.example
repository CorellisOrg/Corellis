# 🦞 Lobster Farm - Environment Variables
# Copy to .env and fill in your values

# === Required: LLM Provider ===
# Option A: AWS Bedrock (recommended for team use)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2

# Option B: Anthropic API directly
# ANTHROPIC_API_KEY=

# === Optional: Enhanced Features ===

# Web search (Brave Search API)
BRAVE_API_KEY=

# Voice (ElevenLabs TTS)
ELEVENLABS_API_KEY=

# Google Gemini (alternative model)
GEMINI_API_KEY=

# Azure OpenAI (for o3/o4 models)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=

# === ACP / Claude Code ===
# Set to 1 to use Bedrock for Claude Code (recommended with AWS setup)
CLAUDE_CODE_USE_BEDROCK=1

# === Thread Behavior ===
# Set to false to require explicit @mention in threads (reduces token burn)
OPENCLAW_THREAD_IMPLICIT_MENTION=false
